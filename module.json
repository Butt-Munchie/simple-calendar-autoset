{
  "id": "simple-calendar-autoset",
  "title": "Simple Calendar Autosettings",
  "version": "1.0.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "esmodules": [
    "main.js"
  ],
  "flags": {
    "canUpload": true
  },
  "packs": [
    {
      "name": "macros",
      "label": "Macros",
      "path": "packs/macros",
      "type": "Macro",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    }
  ],
  "relationships": {
    "requires": [
      {
        "id": "foundryvtt-simple-calendar-reborn",
        "type": "module",
        "compatibility": {}
      }
    ]
  },
  "authors": [
    {
      "name": "Butt-Munch",
      "flags": {}
    }
  ],
  "description": "Autoset client settings for FoundryVTT Simple Calendar Reborn on world load"
}
